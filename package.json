{
  "name": "safe-upgrade",
  "version": "1.0.1",
  "description": "Classify npm dependency updates by risk level — safe, review, or manual",
  "keywords": [
    "npm",
    "dependencies",
    "upgrade",
    "update",
    "semver",
    "security",
    "cli",
    "indie",
    "outdated",
    "audit"
  ],
  "homepage": "https://github.com/revo1290/safe-upgrade#readme",
  "bugs": {
    "url": "https://github.com/revo1290/safe-upgrade/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/revo1290/safe-upgrade.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/revo1290"
  },
  "license": "MIT",
  "author": "revo1290 <hin.ww1290@gmail.com>",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "safe-upgrade": "./dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "prepack": "npm run typecheck && npm run lint && npm run test",
    "release": "changeset publish"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.0.1",
    "semver": "^7.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.7.0",
    "@changesets/cli": "^2.27.0",
    "@types/node": "^20.12.0",
    "@types/semver": "^7.5.8",
    "@vitest/coverage-v8": "^1.5.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
